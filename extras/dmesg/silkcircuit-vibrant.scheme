# SilkCircuit Vibrant — dmesg color scheme
# Install: cp to ~/.config/terminal-colors.d/dmesg.scheme
#
# Colors from SilkCircuit Vibrant variant
# https://github.com/hyperb1iss/silkcircuit-nvim

subsys    38;2;0;255;204
time      38;2;179;102;255
timebreak 38;2;179;102;255
alert     1;38;2;247;140;108
crit      1;38;2;255;51;102
err       38;2;255;51;102
warn      38;2;179;102;255
segfault  1;4;38;2;255;51;102
