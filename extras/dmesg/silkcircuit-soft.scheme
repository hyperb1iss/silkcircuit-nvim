# SilkCircuit Soft — dmesg color scheme
# Install: cp to ~/.config/terminal-colors.d/dmesg.scheme
#
# Colors from SilkCircuit Soft variant
# https://github.com/hyperb1iss/silkcircuit-nvim

subsys    38;2;153;255;238
time      38;2;177;153;255
timebreak 38;2;177;153;255
alert     1;38;2;255;153;221
crit      1;38;2;255;102;119
err       38;2;255;102;119
warn      38;2;177;153;255
segfault  1;4;38;2;255;102;119
